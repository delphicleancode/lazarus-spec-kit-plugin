object dlgSpecSettings: TdlgSpecSettings
  Left = 300
  Height = 570
  Top = 200
  Width = 450
  BorderStyle = bsDialog
  Caption = 'Spec Wizard Settings'
  ClientHeight = 570
  ClientWidth = 450
  Position = poMainFormCenter
  OnCreate = FormCreate
  LCLVersion = '4.4.0.0'

  object pnlMain: TPanel
    Left = 8
    Height = 510
    Top = 8
    Width = 434
    Anchors = [akTop, akLeft, akRight, akBottom]
    BevelOuter = bvNone
    ClientHeight = 510
    ClientWidth = 434
    TabOrder = 0

    object lblProvider: TLabel
      Left = 8
      Height = 15
      Top = 8
      Width = 48
      Caption = 'Provider:'
    end

    object cmbProvider: TComboBox
      Left = 120
      Height = 23
      Top = 4
      Width = 300
      ItemHeight = 15
      Items.Strings = (
        'Groq'
        'Ollama'
      )
      Style = csDropDownList
      TabOrder = 0
      OnChange = cmbProviderChange
    end

    object lblApiKey: TLabel
      Left = 8
      Height = 15
      Top = 44
      Width = 46
      Caption = 'API Key:'
    end

    object edtApiKey: TEdit
      Left = 120
      Height = 23
      Top = 40
      Width = 300
      EchoMode = emPassword
      TabOrder = 1
    end

    object lblModel: TLabel
      Left = 8
      Height = 15
      Top = 80
      Width = 36
      Caption = 'Model:'
    end

    object cmbModel: TComboBox
      Left = 120
      Height = 23
      Top = 76
      Width = 300
      ItemHeight = 15
      Items.Strings = (
        'llama-3.3-70b-versatile'
        'llama-3.1-8b-instant'
        'mixtral-8x7b-32768'
        'gemma2-9b-it'
      )
      TabOrder = 2
    end

    object lblOllamaURL: TLabel
      Left = 8
      Height = 15
      Top = 116
      Width = 66
      Caption = 'Ollama URL:'
    end

    object edtOllamaURL: TEdit
      Left = 120
      Height = 23
      Top = 112
      Width = 300
      TabOrder = 3
      Text = 'http://localhost:11434'
    end

    object lblMaxTokens: TLabel
      Left = 8
      Height = 15
      Top = 152
      Width = 63
      Caption = 'Max Tokens:'
    end

    object seMaxTokens: TSpinEdit
      Left = 120
      Height = 23
      Top = 148
      Width = 120
      MaxValue = 32768
      MinValue = 256
      TabOrder = 4
      Value = 4096
    end

    object lblTemperature: TLabel
      Left = 8
      Height = 15
      Top = 188
      Width = 72
      Caption = 'Temperature:'
    end

    object edtTemperature: TEdit
      Left = 120
      Height = 23
      Top = 184
      Width = 120
      TabOrder = 5
      Text = '0.7'
    end

    object lblSpecKitPath: TLabel
      Left = 8
      Height = 15
      Top = 224
      Width = 87
      Caption = 'Spec-Kit Path:'
    end

    object deSpecKitPath: TDirectoryEdit
      Left = 120
      Height = 23
      Top = 220
      Width = 300
      ShowHidden = False
      ButtonWidth = 23
      NumGlyphs = 1
      TabOrder = 6
    end

    object lblLanguage: TLabel
      Left = 8
      Height = 15
      Top = 264
      Width = 50
      Caption = 'Language:'
    end

    object cmbLanguage: TComboBox
      Left = 120
      Height = 23
      Top = 260
      Width = 180
      ItemHeight = 15
      Items.Strings = (
        'English'
        'Português (BR)'
      )
      Style = csDropDownList
      TabOrder = 7
    end

    object btnTestConnection: TButton
      Left = 120
      Height = 30
      Top = 304
      Width = 130
      Caption = 'Test Connection'
      TabOrder = 8
      OnClick = btnTestConnectionClick
    end

    object gbAutoComplete: TGroupBox
      Left = 8
      Height = 120
      Top = 346
      Width = 418
      Caption = 'AI Autocomplete'
      ClientHeight = 100
      ClientWidth = 414
      TabOrder = 9

      object chkAutoComplete: TCheckBox
        Left = 12
        Height = 19
        Top = 8
        Width = 200
        Caption = 'Enable AI Autocomplete (Ctrl+Alt+Space)'
        Checked = True
        State = cbChecked
        TabOrder = 0
      end

      object lblACMaxTokens: TLabel
        Left = 12
        Height = 15
        Top = 40
        Width = 63
        Caption = 'Max Tokens:'
      end

      object seACMaxTokens: TSpinEdit
        Left = 140
        Height = 23
        Top = 36
        Width = 100
        MaxValue = 1024
        MinValue = 64
        TabOrder = 1
        Value = 256
      end

      object lblACTemperature: TLabel
        Left = 12
        Height = 15
        Top = 72
        Width = 72
        Caption = 'Temperature:'
      end

      object edtACTemperature: TEdit
        Left = 140
        Height = 23
        Top = 68
        Width = 100
        TabOrder = 2
        Text = '0.2'
      end
    end
  end

  object btnOK: TButton
    Left = 276
    Height = 30
    Top = 530
    Width = 80
    Anchors = [akRight, akBottom]
    Caption = 'OK'
    Default = True
    TabOrder = 1
    OnClick = btnOKClick
  end

  object btnCancel: TButton
    Left = 362
    Height = 30
    Top = 530
    Width = 80
    Anchors = [akRight, akBottom]
    Cancel = True
    Caption = 'Cancel'
    ModalResult = 2
    TabOrder = 2
  end
end
